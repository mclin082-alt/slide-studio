NODE_ENV=production
PORT=5173

# Persist SQLite and generated HTML/PDF files on a deploy disk.
SLIDE_STUDIO_DATA_DIR=/var/data

# Optional: if you deploy with the frontend-slides skill assets mounted.
FRONTEND_SLIDES_DIR=/app/frontend-slides

# Optional AI provider defaults for the demo account.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1
OPENAI_API_KEY=

# Portfolio demo account. Set SEED_DEMO=false to disable auto-seeding.
SEED_DEMO=true
DEMO_EMAIL=demo@slidestudio.local
DEMO_PASSWORD=demo1234

# PDF export. Dockerfile installs Chromium at this path.
CHROME_PATH=/usr/bin/chromium
